# ─── Liquid Trading ───────────────────────────────────────────────────────────
LIQUID_API_KEY=your_liquid_api_key_here
LIQUID_API_SECRET=your_liquid_api_secret_here
LIQUID_BASE_URL=https://api.liquid.com          # use https://api.sandbox.liquid.com for testing

# ─── Anthropic ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here
CLAUDE_MODEL=claude-3-5-sonnet-20241022

# ─── News Sources ─────────────────────────────────────────────────────────────
CRYPTOPANIC_API_KEY=your_cryptopanic_key_here   # free at cryptopanic.com/developers/api/
MARKETAUX_API_KEY=your_marketaux_key_here       # free (100 req/day) at marketaux.com
X_BEARER_TOKEN=your_x_bearer_token_here         # X API v2 Bearer Token
USE_MOCK_NEWS=false                             # set true to skip external API calls

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=8000
HOST=0.0.0.0
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ─── Frontend ─────────────────────────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:8000
